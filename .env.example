# LLM
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen3-max
LLM_ENABLED=false
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=
LLM_MODEL=qwen3-max
LLM_TIMEOUT_SECONDS=30
LLM_MAX_TOKENS=1200
LLM_TEMPERATURE=0.2
LLM_ONLY_FOR_REVIEW=true
LLM_MIN_RISK_LEVEL=high
LLM_UNKNOWN_CLASSIFIER_ENABLED=false
LLM_UNKNOWN_CLASSIFIER_MAX_TOKENS=500
LLM_UNKNOWN_CLASSIFIER_MIN_CONFIDENCE=0.7

# Threat intelligence
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=
THREAT_INTEL_ABUSEIPDB_ENABLED=false
THREAT_INTEL_VIRUSTOTAL_ENABLED=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_EVENT_STREAM=security:events
REDIS_ALERT_STREAM=security:alerts
REDIS_DEADLETTER_STREAM=security:deadletter
REDIS_MEMORY_PREFIX=memory:ip
SESSION_RESULT_PREFIX=security:result
SESSION_MEMORY_PREFIX=security:session
SESSION_MEMORY_TTL_SECONDS=86400

# Database
SECAGENT_DB_PATH=data/secagent.db
DATABASE_URL=
ALERT_AGGREGATION_WINDOW_SECONDS=300

# Frontend / backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5173
FRONTEND_PREVIEW_PORT=4173
VITE_API_BASE_URL=http://127.0.0.1:8000

# WAF
WAF_PORT=8080
WAF_BASE_URL=http://127.0.0.1:8080
WAF_SERVER_NAME=_
WAF_PROXY_PASS=http://business-demo:3000
WAF_CLIENT_MAX_BODY_SIZE=10m
WAF_PROXY_CONNECT_TIMEOUT=10s
WAF_PROXY_SEND_TIMEOUT=30s
WAF_PROXY_READ_TIMEOUT=30s
WAF_AUDIT_LOG_PATH=data/waf_logs/modsecurity/audit/audit.log
WAF_COLLECTOR_OFFSET_PATH=data/waf_logs/.collector.offset
WAF_COLLECTOR_IGNORED_PATHS=/__waf_health
WAF_COLLECTOR_DROP_BENIGN=true
WAF_COLLECTOR_STATIC_EXTENSIONS=.css,.js,.png,.jpg,.jpeg,.gif,.svg,.ico,.woff,.woff2,.map
WAF_COLLECTOR_SENSITIVE_PATHS=/admin,/api,/login,/upload,/download,/search
WAF_COLLECTOR_SUSPICIOUS_USER_AGENTS=sqlmap,nikto,nmap,masscan,acunetix,nessus
WAF_COLLECTOR_ATTACK_KEYWORDS=union select, or ,<script,../,..%2f,/etc/passwd,sleep(,benchmark(,cmd=
WAF_NGINX_LOG_DIR=./data/waf_logs/nginx
WAF_MODSEC_LOG_DIR=./data/waf_logs/modsecurity
MODSEC_RULE_ENGINE=on
MODSEC_AUDIT_ENGINE=RelevantOnly
MODSEC_AUDIT_LOG_FORMAT=JSON
MODSEC_AUDIT_LOG_TYPE=Serial
MODSEC_AUDIT_LOG=/var/log/modsecurity/audit/audit.log
MODSEC_AUDIT_STORAGE_DIR=/var/log/modsecurity/audit

# Business demo upstream
BUSINESS_DEMO_PORT=3000

# Consumer
EVENT_CONSUMER_START_ID=0-0
EVENT_CONSUMER_OFFSET_PATH=data/redis/.event_consumer.offset
EVENT_CONSUMER_IGNORED_PATHS=/__waf_health
EVENT_CONSUMER_COUNT=10
EVENT_CONSUMER_BLOCK_MS=1000
EVENT_CONSUMER_INTERVAL=1.0

# Vector retrieval placeholder
EMBEDDING_ENABLED=false
EMBEDDING_PROVIDER=dashscope
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_DIMENSION=1024
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_BATCH_SIZE=16
MILVUS_ENABLED=false
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_DATABASE=default
MILVUS_KNOWLEDGE_COLLECTION=secagent_knowledge_chunks
MILVUS_MEMORY_COLLECTION=secagent_analysis_memory
MILVUS_INDEX_TYPE=AUTOINDEX
MILVUS_METRIC_TYPE=COSINE
MILVUS_TOP_K=5

# Long-term analysis memory
LONG_TERM_MEMORY_ENABLED=false
LONG_TERM_MEMORY_SEARCH_ENABLED=false
LONG_TERM_MEMORY_MIN_RISK_LEVEL=high
LONG_TERM_MEMORY_WRITE_AUTO_CLOSED=false
LONG_TERM_MEMORY_REQUIRE_ANALYST_NOTE=false

# Runtime
MEM_LIMIT=8073741824
TIMEZONE=Asia/Shanghai
